@model AdminOrderDetailVm
@{
    ViewData["Title"] = "Pedido " + Model.OrderNumber;
    var status = TempData["StatusMessage"] as string;
    var badge = Model.Status.Badge();
}

<div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
    <div>
        <h1 class="h4 mb-1">Pedido @Model.OrderNumber</h1>
        <span class="badge @badge.Css">@badge.Text</span>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Volver</a>
</div>

@if (!string.IsNullOrEmpty(status))
{
    <div class="alert alert-info" role="alert">@status</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th class="text-end">Precio</th>
                            <th class="text-center">Cant.</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in Model.Items)
                        {
                            <tr>
                                <td>@i.ProductName</td>
                                <td class="text-end">$@i.UnitPrice.ToString("N2")</td>
                                <td class="text-center">@i.Quantity</td>
                                <td class="text-end">$@i.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Total</th>
                            <th class="text-end">$@Model.Total.ToString("N2")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h6 class="text-uppercase text-muted mb-3">Cliente y envío</h6>
                <p class="mb-1 small text-muted">@Model.CustomerEmail</p>
                <p class="mb-1"><strong>@Model.ContactName</strong></p>
                <p class="mb-1">@Model.ContactPhone</p>
                <p class="mb-3">@Model.ShippingAddress</p>
                <p class="text-muted small mb-0">Creado: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                @if (Model.UpdatedAt.HasValue)
                {
                    <p class="text-muted small mb-0">Actualizado: @Model.UpdatedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-uppercase text-muted mb-3">Cambiar estado</h6>
                @if (Model.AllowedTransitions.Count == 0)
                {
                    <p class="text-muted small mb-0">El pedido está en un estado final. No hay acciones disponibles.</p>
                }
                else
                {
                    <form asp-action="ChangeStatus" method="post" class="d-flex gap-2">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <select name="newStatus" class="form-select">
                            @foreach (var s in Model.AllowedTransitions)
                            {
                                <option value="@s">@s.Badge().Text</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-dark">Aplicar</button>
                    </form>
                    <p class="text-muted small mt-2 mb-0">Cancelar repone stock (salvo que ya estuviera Entregado).</p>
                }
            </div>
        </div>
    </div>
</div>

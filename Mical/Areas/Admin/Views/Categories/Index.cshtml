@model IReadOnlyList<AdminCategoryListItemVm>
@{
    ViewData["Title"] = "Categorías";
    var status = TempData["StatusMessage"] as string;
}

<div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
    <h1 class="h3 mb-0">Categorías</h1>
    <a class="btn btn-dark" asp-action="Create">Nueva categoría</a>
</div>

@if (!string.IsNullOrEmpty(status))
{
    <div class="alert alert-success" role="alert">@status</div>
}

@if (Model.Count == 0)
{
    <p class="text-muted">Todavía no hay categorías. Creá la primera.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle bg-white">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Estado</th>
                    <th>Creada</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Name</td>
                        <td>
                            @if (c.IsActive)
                            {
                                <span class="badge bg-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactiva</span>
                            }
                        </td>
                        <td>@c.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@c.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@c.Id">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@model AdminCategoryListItemVm
@{
    ViewData["Title"] = "Eliminar categoría";
}

<div class="border-bottom pb-2 mb-4">
    <h1 class="h3 mb-0">Eliminar categoría</h1>
</div>

<div class="card border-0 shadow-sm" style="max-width:640px;">
    <div class="card-body p-4">
        <p>¿Seguro que querés eliminar la categoría <strong>@Model.Name</strong>?</p>
        <p class="text-muted small">
            Es un borrado lógico: la categoría se oculta pero no se pierde el historial.
        </p>

        <form asp-action="Delete" method="post" class="d-flex gap-2">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger px-4">Sí, eliminar</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
        </form>
    </div>
</div>

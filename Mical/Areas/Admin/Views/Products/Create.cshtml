@model ProductFormVm
@{
    ViewData["Title"] = "Nuevo producto";
}

<div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
    <h1 class="h3 mb-0">Nuevo producto</h1>
    <a class="btn btn-outline-secondary" asp-action="Index">Volver</a>
</div>

<div class="card border-0 shadow-sm" style="max-width:760px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                        <option value="">— Elegí una categoría —</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Image" class="form-label"></label>
                    <input asp-for="Image" type="file" accept="image/*" class="form-control" />
                    <div class="form-text">JPG, PNG o WEBP. Máx. 2 MB.</div>
                    <span asp-validation-for="Image" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SalePrice" class="form-label"></label>
                    <input asp-for="SalePrice" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="SalePrice" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Stock" class="form-label"></label>
                    <input asp-for="Stock" type="number" min="0" class="form-control" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MinStock" class="form-label"></label>
                    <input asp-for="MinStock" type="number" min="0" class="form-control" />
                    <span asp-validation-for="MinStock" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-dark px-4">Crear</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model IReadOnlyList<AdminProductListItemVm>
@{
    ViewData["Title"] = "Productos";
    var status = TempData["StatusMessage"] as string;
}

<div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
    <h1 class="h3 mb-0">Productos</h1>
    <a class="btn btn-dark" asp-action="Create">Nuevo producto</a>
</div>

@if (!string.IsNullOrEmpty(status))
{
    <div class="alert alert-success" role="alert">@status</div>
}

@if (Model.Count == 0)
{
    <p class="text-muted">Todavía no hay productos. Creá el primero.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle bg-white">
            <thead>
                <tr>
                    <th></th>
                    <th>SKU</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th class="text-end">Precio</th>
                    <th class="text-end">Stock</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td style="width:52px;">
                            @if (!string.IsNullOrEmpty(p.ImagePath))
                            {
                                <img src="~/@p.ImagePath" alt="@p.Name" width="44" height="44" style="object-fit:cover;border-radius:6px;" />
                            }
                            else
                            {
                                <span class="d-inline-block bg-light border rounded" style="width:44px;height:44px;"></span>
                            }
                        </td>
                        <td class="small text-muted">@p.Sku</td>
                        <td>@p.Name</td>
                        <td>@p.CategoryName</td>
                        <td class="text-end">
                            @if (p.SalePrice.HasValue)
                            {
                                <span class="text-decoration-line-through text-muted me-1">@p.Price.ToString("N2")</span>
                                <strong>@p.EffectivePrice.ToString("N2")</strong>
                            }
                            else
                            {
                                <span>@p.Price.ToString("N2")</span>
                            }
                        </td>
                        <td class="text-end">
                            @p.Stock
                            @if (p.Stock <= 0)
                            {
                                <span class="badge bg-danger ms-1">Sin stock</span>
                            }
                            else if (p.IsLowStock)
                            {
                                <span class="badge bg-warning text-dark ms-1">Bajo</span>
                            }
                        </td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@p.Id">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@model ProductDetailVm
@{
    ViewData["Title"] = Model.Name;
}

<section class="py-5" style="margin-top:90px;">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Index" class="text-decoration-none">Tienda</a></li>
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Index" asp-route-categoria="@Model.CategoryId" class="text-decoration-none">@Model.CategoryName</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>

        <div class="row g-5">
            <div class="col-md-6">
                <div class="bg-light rounded" style="aspect-ratio:1/1;overflow:hidden;">
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <img src="~/@Model.ImagePath" alt="@Model.Name" class="w-100 h-100" style="object-fit:cover;" />
                    }
                </div>
            </div>

            <div class="col-md-6">
                <p class="text-muted small text-uppercase mb-1">@Model.CategoryName</p>
                <h1 class="h2 mb-3">@Model.Name</h1>

                <div class="mb-3">
                    @if (Model.IsOnSale)
                    {
                        <span class="text-decoration-line-through text-muted me-2 fs-5">$@Model.Price.ToString("N2")</span>
                        <span class="fs-3 fw-bold">$@Model.EffectivePrice.ToString("N2")</span>
                        <span class="badge bg-success ms-2">Oferta</span>
                    }
                    else
                    {
                        <span class="fs-3 fw-bold">$@Model.EffectivePrice.ToString("N2")</span>
                    }
                </div>

                @if (Model.IsOutOfStock)
                {
                    <p><span class="badge bg-danger">Sin stock</span></p>
                    <button type="button" class="btn btn-dark btn-lg px-4" disabled>Agregar al carrito</button>
                }
                else
                {
                    <p class="text-success small mb-3">Disponible · @Model.Stock en stock</p>
                    @* El carrito (LocalStorage) se implementa en la Fase 5. *@
                    <button type="button" class="btn btn-dark btn-lg px-4 js-add-to-cart"
                            data-product-id="@Model.Id" disabled title="Disponible en la Fase 5">
                        Agregar al carrito
                    </button>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <hr class="my-4" />
                    <h6 class="text-uppercase text-muted">Descripción</h6>
                    <p class="mb-0" style="white-space:pre-line;">@Model.Description</p>
                }

                <hr class="my-4" />
                <p class="text-muted small mb-0">SKU: @Model.Sku</p>
            </div>
        </div>
    </div>
</section>

@model OrderDetailVm
@{
    ViewData["Title"] = "Pedido " + Model.OrderNumber;
    var justPlaced = ViewData["JustPlaced"] as bool? ?? false;
    var (cls, txt) = Model.Status.Badge();
}

<section class="py-5" style="margin-top:90px;">
    <div class="container">
        @if (justPlaced)
        {
            <div class="alert alert-success">
                <h5 class="mb-1">¡Gracias por tu compra! 🎉</h5>
                <p class="mb-0">Tu pedido <strong>@Model.OrderNumber</strong> quedó registrado. Te contactaremos para coordinar el pago y el envío.</p>
            </div>
        }

        <div class="d-flex flex-wrap justify-content-between align-items-center border-bottom pb-3 mb-4">
            <h1 class="h4 mb-0">Pedido @Model.OrderNumber</h1>
            <span class="badge @cls">@txt</span>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-end">Precio</th>
                                <th class="text-center">Cant.</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var i in Model.Items)
                            {
                                <tr>
                                    <td>@i.ProductName</td>
                                    <td class="text-end">$@i.UnitPrice.ToString("N2")</td>
                                    <td class="text-center">@i.Quantity</td>
                                    <td class="text-end">$@i.LineTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-end">Total</th>
                                <th class="text-end">$@Model.Total.ToString("N2")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <a asp-controller="Shop" asp-action="Index" class="text-decoration-none">← Seguir comprando</a>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h6 class="text-uppercase text-muted mb-3">Envío</h6>
                        <p class="mb-1"><strong>@Model.ContactName</strong></p>
                        <p class="mb-1">@Model.ContactPhone</p>
                        <p class="mb-3">@Model.ShippingAddress</p>
                        <p class="text-muted small mb-0">Fecha: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (justPlaced)
{
    @section Scripts {
        <script>
            // El pedido consumió el carrito: se limpia LocalStorage.
            if (window.Cart) { window.Cart.clear(); }
        </script>
    }
}

@model ChangePasswordVm
@{
    ViewData["Title"] = "Cambiar contraseña";
}

<section class="auth-section py-5" style="margin-top:100px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 p-md-5">
                        <h1 class="h3 mb-4 text-center">Cambiar contraseña</h1>

                        <form asp-action="ChangePassword" method="post" novalidate>
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="CurrentPassword" class="form-label"></label>
                                <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="NewPassword" class="form-label"></label>
                                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                                <div class="form-text">Mínimo 8 caracteres, con mayúscula, minúscula y número.</div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ConfirmNewPassword" class="form-label"></label>
                                <input asp-for="ConfirmNewPassword" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-dark w-100 py-2">Guardar</button>
                        </form>

                        <p class="text-center mt-4 mb-0">
                            <a asp-action="Profile">Volver al perfil</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

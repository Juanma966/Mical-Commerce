@model ShopIndexVm
@{
    ViewData["Title"] = "Tienda";
    var p = Model.Products;
}

<section class="py-5" style="margin-top:90px;">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center border-bottom pb-3 mb-4">
            <h1 class="h3 mb-2 mb-md-0">Tienda</h1>
            <form method="get" asp-controller="Shop" asp-action="Index" class="d-flex" role="search" style="max-width:360px;">
                @if (Model.SelectedCategoryId.HasValue)
                {
                    <input type="hidden" name="categoria" value="@Model.SelectedCategoryId" />
                }
                <input type="search" name="q" value="@Model.Query" class="form-control me-2" placeholder="Buscar productos…" />
                <button type="submit" class="btn btn-dark">Buscar</button>
            </form>
        </div>

        <div class="row">
            <!-- Filtro por categoría -->
            <aside class="col-lg-3 mb-4">
                <h6 class="text-uppercase text-muted mb-3">Categorías</h6>
                <ul class="list-unstyled">
                    <li class="mb-2">
                        <a asp-controller="Shop" asp-action="Index" asp-route-q="@Model.Query"
                           class="text-decoration-none @(Model.SelectedCategoryId == null ? "fw-bold text-dark" : "text-muted")">
                            Todas
                        </a>
                    </li>
                    @foreach (var c in Model.Categories)
                    {
                        <li class="mb-2">
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoria="@c.Id" asp-route-q="@Model.Query"
                               class="text-decoration-none @(Model.SelectedCategoryId == c.Id ? "fw-bold text-dark" : "text-muted")">
                                @c.Name
                            </a>
                        </li>
                    }
                </ul>
            </aside>

            <!-- Grilla de productos -->
            <div class="col-lg-9">
                @if (p.TotalCount == 0)
                {
                    <div class="text-center text-muted py-5">
                        <p class="mb-0">No encontramos productos@(string.IsNullOrEmpty(Model.Query) ? "" : $" para “{Model.Query}”").</p>
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-3">@p.TotalCount producto(s)</p>
                    <div class="row g-4">
                        @foreach (var item in p.Items)
                        {
                            <div class="col-6 col-md-4">
                                <div class="card h-100 border-0 shadow-sm">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-reset">
                                        <div class="position-relative bg-light" style="aspect-ratio:1/1;overflow:hidden;">
                                            @if (!string.IsNullOrEmpty(item.ImagePath))
                                            {
                                                <img src="~/@item.ImagePath" alt="@item.Name" class="w-100 h-100" style="object-fit:cover;" />
                                            }
                                            @if (item.IsOutOfStock)
                                            {
                                                <span class="badge bg-danger position-absolute top-0 start-0 m-2">Sin stock</span>
                                            }
                                            else if (item.IsOnSale)
                                            {
                                                <span class="badge bg-success position-absolute top-0 start-0 m-2">Oferta</span>
                                            }
                                        </div>
                                        <div class="card-body">
                                            <h6 class="card-title mb-1">@item.Name</h6>
                                            <div>
                                                @if (item.IsOnSale)
                                                {
                                                    <span class="text-decoration-line-through text-muted me-1">@item.Price.ToMoney()</span>
                                                    <strong>@item.EffectivePrice.ToMoney()</strong>
                                                }
                                                else
                                                {
                                                    <strong>@item.EffectivePrice.ToMoney()</strong>
                                                }
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>

                    @if (p.TotalPages > 1)
                    {
                        <nav class="mt-4" aria-label="Paginación">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(p.HasPrevious ? "" : "disabled")">
                                    <a class="page-link" asp-controller="Shop" asp-action="Index"
                                       asp-route-categoria="@Model.SelectedCategoryId" asp-route-q="@Model.Query" asp-route-page="@(p.Page - 1)">
                                        Anterior
                                    </a>
                                </li>
                                @for (var i = 1; i <= p.TotalPages; i++)
                                {
                                    <li class="page-item @(i == p.Page ? "active" : "")">
                                        <a class="page-link" asp-controller="Shop" asp-action="Index"
                                           asp-route-categoria="@Model.SelectedCategoryId" asp-route-q="@Model.Query" asp-route-page="@i">@i</a>
                                    </li>
                                }
                                <li class="page-item @(p.HasNext ? "" : "disabled")">
                                    <a class="page-link" asp-controller="Shop" asp-action="Index"
                                       asp-route-categoria="@Model.SelectedCategoryId" asp-route-q="@Model.Query" asp-route-page="@(p.Page + 1)">
                                        Siguiente
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</section>

@*
    Pie del sitio público. Adaptado de MiniStore.
*@
<footer id="footer" class="overflow-hidden">
    <div class="container">
        <div class="row">
            <div class="footer-top-area">
                <div class="row d-flex flex-wrap justify-content-between">
                    <div class="col-lg-3 col-sm-6 pb-3">
                        <div class="footer-menu">
                            <img src="~/images/main-logo.png" alt="Mical">
                            <p>Regalería e imprenta. Productos con diseño para toda ocasión.</p>
                            <div class="social-links">
                                <ul class="d-flex list-unstyled">
                                    <li><a href="#"><svg class="facebook"><use xlink:href="#facebook" /></svg></a></li>
                                    <li><a href="#"><svg class="instagram"><use xlink:href="#instagram" /></svg></a></li>
                                    <li><a href="#"><svg class="twitter"><use xlink:href="#twitter" /></svg></a></li>
                                    <li><a href="#"><svg class="linkedin"><use xlink:href="#linkedin" /></svg></a></li>
                                    <li><a href="#"><svg class="youtube"><use xlink:href="#youtube" /></svg></a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-2 col-sm-6 pb-3">
                        <div class="footer-menu text-uppercase">
                            <h5 class="widget-title pb-2">Enlaces</h5>
                            <ul class="menu-list list-unstyled text-uppercase">
                                <li class="menu-item pb-2"><a asp-area="" asp-controller="Home" asp-action="Index">Inicio</a></li>
                                <li class="menu-item pb-2"><a href="#">Productos</a></li>
                                <li class="menu-item pb-2"><a href="#">Nosotros</a></li>
                                <li class="menu-item pb-2"><a href="#">Contacto</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 pb-3">
                        <div class="footer-menu text-uppercase">
                            <h5 class="widget-title pb-2">Ayuda e info</h5>
                            <ul class="menu-list list-unstyled">
                                <li class="menu-item pb-2"><a href="#">Seguí tu pedido</a></li>
                                <li class="menu-item pb-2"><a href="#">Cambios y devoluciones</a></li>
                                <li class="menu-item pb-2"><a href="#">Envíos</a></li>
                                <li class="menu-item pb-2"><a href="#">Contacto</a></li>
                                <li class="menu-item pb-2"><a href="#">Preguntas frecuentes</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 pb-3">
                        <div class="footer-menu contact-item">
                            <h5 class="widget-title text-uppercase pb-2">Contacto</h5>
                            <p>¿Tenés consultas o sugerencias? <a href="mailto:">info@mical.com</a></p>
                            <p>¿Necesitás ayuda? Llamanos. <a href="">+54 11 2222 3333</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <hr>
</footer>
<div id="footer-bottom">
    <div class="container">
        <div class="row d-flex flex-wrap justify-content-between">
            <div class="col-md-4 col-sm-6">
                <div class="Shipping d-flex">
                    <p>Enviamos con:</p>
                    <div class="card-wrap ps-2">
                        <img src="~/images/dhl.png" alt="envío">
                        <img src="~/images/shippingcard.png" alt="envío">
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="payment-method d-flex">
                    <p>Medios de pago:</p>
                    <div class="card-wrap ps-2">
                        <img src="~/images/visa.jpg" alt="visa">
                        <img src="~/images/mastercard.jpg" alt="mastercard">
                        <img src="~/images/paypal.jpg" alt="paypal">
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="copyright">
                    <p>© @DateTime.Now.Year Mical. Todos los derechos reservados.</p>
                </div>
            </div>
        </div>
    </div>
</div>
